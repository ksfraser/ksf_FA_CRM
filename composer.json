{
    "name": "ksfraser/ksf-fa-crm",
    "description": "FrontAccounting CRM Adapter",
    "type": "fa-module",
    "require": {
        "php": ">=7.4",
        "ksfraser/exceptions": "^1.2",
        "ksfraser/traits": "^1.2",
        "ksfraser/rbac": "*",
        "ksfraser/gedcom": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\FA\\CRM\\": "src/Ksfraser/FA/CRM/",
            "Ksfraser\\FA\\CRM\\Services\\": "includes/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../ksf_CRM",
            "canonical": false
        },
        {
            "type": "path",
            "url": "../ksf_RBAC",
            "canonical": false
        },
        {
            "type": "path",
            "url": "../Traits",
            "canonical": false
        },
        {
            "type": "vcs",
            "url": "https://github.com/ksfraser/ksf_CRM_GEDCOM"
        }
    ]
}
